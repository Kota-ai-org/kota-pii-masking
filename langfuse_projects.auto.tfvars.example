# Copy to langfuse_projects.auto.tfvars and fill in real keys.
# The real file matches *.tfvars in .gitignore, so it is never committed.
# tofu auto-loads *.auto.tfvars, so deploy.sh picks it up with no extra flags.
#
# One entry per Langfuse project. `name` is a slug (lowercase, hyphens, <=30
# chars, unique) used in resource names and the output subdir exports/<name>/.
# `host` is optional and defaults to https://us.cloud.langfuse.com — set it per
# project for EU (https://cloud.langfuse.com) or a self-hosted base URL.
# `extra_headers` is optional — set it when the host sits behind an
# authenticating proxy (e.g. Cloudflare Access service tokens); the headers are
# sent on every request and stored in Secret Manager, never committed.

langfuse_projects = [
  {
    name       = "support-bot"
    public_key = "pk-lf-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
    secret_key = "sk-lf-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
    host       = "https://us.cloud.langfuse.com"
  },
  {
    # Self-hosted Langfuse behind Cloudflare Access: requests must carry the
    # service-token headers or Cloudflare blocks them before Langfuse sees them.
    name       = "internal-agent"
    public_key = "pk-lf-zzzzzzzz-zzzz-zzzz-zzzz-zzzzzzzzzzzz"
    secret_key = "sk-lf-zzzzzzzz-zzzz-zzzz-zzzz-zzzzzzzzzzzz"
    host       = "https://langfuse.internal.example.com"
    extra_headers = {
      "CF-Access-Client-Id"     = "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.access"
      "CF-Access-Client-Secret" = "yyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyy"
    }
  },
  {
    name       = "sales-agent"
    public_key = "pk-lf-yyyyyyyy-yyyy-yyyy-yyyy-yyyyyyyyyyyy"
    secret_key = "sk-lf-yyyyyyyy-yyyy-yyyy-yyyy-yyyyyyyyyyyy"
    # host omitted -> defaults to https://us.cloud.langfuse.com
  },
]
